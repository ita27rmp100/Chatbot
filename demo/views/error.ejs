<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Error</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 40px; background: #f7f7f7; color: #333; }
    .container { max-width: 600px; margin: auto; padding: 24px; background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.12); }
    h1 { margin-top: 0; color: #d33; }
    pre { background: #f0f0f0; padding: 12px; border-radius: 4px; overflow-x: auto; }
    a { color: #007acc; text-decoration: none; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Something went wrong</h1>
    <p><%= message || "An unexpected error occurred." %></p>
    <% if (error && error.stack) { %>
      <pre><%= error.stack %></pre>
    <% } %>
    <p><a href="/">Return to home</a></p>
  </div>
</body>
</html>
